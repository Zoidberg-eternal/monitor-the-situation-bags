# === Python Risk Engine ===
HL_CACHE_TTL=60
HOST=0.0.0.0
PORT=8402

# === Bags.fm Token Monitoring ===
# Get your API key from https://dev.bags.fm
# REQUIRED — the public feed endpoint now rejects unauthenticated requests (401).
# All Bags.fm calls (launch feed, pool info, lifetime fees, quotes) need this.
BAGS_FM_API_KEY=your_bags_fm_api_key_here

# === MiroShark Swarm LLM (JUDGE-SUPPLIED — same class as SOLANA_ADDRESS) ===
# YOU supply LLM_API_KEY (OpenAI-compatible); it is never shipped in this repo.
# Behavior contract:
#   valid key                    -> non-null simulation_consensus (points 2 & 3)
#   absent / invalid / expired   -> graceful Posture-B degradation: structured
#                                   HTTP 200, simulation_consensus: null +
#                                   simulation_note. Never a silent null/crash.
#                                   (expired/wrong key == "no key": expected.)
# The knowledge graph is always auto-seeded on a fresh Neo4j (no extra step),
# so an empty graph is never the cause of a null consensus.
# Defaults below target OpenRouter + mimo; for OpenAI set
#   LLM_BASE_URL=https://api.openai.com/v1  LLM_MODEL_NAME=gpt-4o-mini
LLM_PROVIDER=openai
LLM_API_KEY=your_openrouter_api_key_here
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL_NAME=xiaomi/mimo-v2-flash
# Embeddings power each agent's knowledge-graph retrieval during the debate.
# By DEFAULT they use OpenAI embeddings and REUSE LLM_API_KEY (no Ollama, no
# extra service, no extra credential) — the documented one command runs the
# debate end-to-end with just LLM_API_KEY. Defaults: EMBEDDING_PROVIDER=openai,
# EMBEDDING_BASE_URL=https://api.openai.com (host root, NOT /v1 — the service
# appends /v1/embeddings), EMBEDDING_API_KEY=$LLM_API_KEY,
# EMBEDDING_MODEL=text-embedding-3-small, EMBEDDING_DIMENSIONS=1536.
# Override only for a different embedding backend:
#EMBEDDING_BASE_URL=https://api.openai.com
#EMBEDDING_MODEL=text-embedding-3-small

# === Solana x402 Gateway (primary for Bags Hackathon) ===
# Your Solana devnet wallet public key (base58). The gateway exits on startup
# if unset — supply a REAL devnet pubkey here (smoke-test point 4).
SOLANA_ADDRESS=YOUR_SOLANA_PUBKEY_HERE

# Network: "devnet" or "mainnet-beta"
SOLANA_NETWORK=devnet

# Solana RPC endpoint
SOLANA_RPC_URL=https://api.devnet.solana.com

# === Stellar x402 Gateway (alternate) ===
# Gateway port (separate from risk engine)
# GATEWAY_PORT=3402

# Your Stellar public key (starts with G)
STELLAR_ADDRESS=GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# OpenZeppelin Channels API key
# Testnet: https://channels.openzeppelin.com/testnet/gen
# Mainnet: https://channels.openzeppelin.com/gen
OPENZEPPELIN_API_KEY=your_api_key_here

# Network: "testnet" or "mainnet"
STELLAR_NETWORK=testnet

# Upstream risk engine URL
UPSTREAM_URL=http://localhost:8402
